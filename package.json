{
	"name": "stratum",
	"displayName": "Stratum",
	"description": "AI-powered VSCode extension template",
	"version": "0.0.1",
	"publisher": "stratum",
	"repository": {
		"type": "git",
		"url": "https://github.com/Kosha-Nirman/stratum"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"vscode": "^1.85.0",
		"node": ">=22"
	},
	"contributes": {
		"commands": [
			{
				"command": "stratum.openPanel",
				"title": "Stratum: Open Panel",
				"icon": "$(layout-panel)"
			},
			{
				"command": "stratum.helloWorld",
				"title": "Stratum: Hello World"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "stratum-sidebar",
					"title": "Stratum",
					"icon": "assets/icon.svg"
				}
			]
		},
		"views": {
			"stratum-sidebar": [
				{
					"id": "stratum.sidebarView",
					"name": "Stratum",
					"type": "webview"
				}
			]
		}
	},
	"scripts": {
		"install:all": "pnpm install && cd webview-ui && pnpm install",
		"build": "pnpm run build:webview && pnpm run build:extension",
		"build:extension": "node esbuild.config.mjs",
		"build:webview": "cd webview-ui && pnpm run build",
		"watch": "concurrently \"pnpm run watch:extension\" \"pnpm run watch:webview\"",
		"watch:extension": "node esbuild.config.mjs --watch",
		"watch:webview": "cd webview-ui && pnpm run dev",
		"package": "vsce package",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
		"lint": "biome lint src webview-ui/src",
		"lint:fix": "biome lint --write src webview-ui/src",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.0",
		"@types/vscode": "^1.110.0",
		"@vscode/test-electron": "^2.5.2",
		"concurrently": "^9.2.1",
		"esbuild": "^0.28.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
