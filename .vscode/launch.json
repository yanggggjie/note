{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": ["--extensionDevelopmentPath=${workspaceFolder}"],
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "npm: build:extension",
			"sourceMaps": true
		},
		{
			"name": "Run Extension (with Webview Dev Server)",
			"type": "extensionHost",
			"request": "launch",
			"args": ["--extensionDevelopmentPath=${workspaceFolder}"],
			"outFiles": ["${workspaceFolder}/dist/**/*.js"],
			"preLaunchTask": "npm: build:extension",
			"sourceMaps": true,
			"env": {
				"VITE_DEV_SERVER_URL": "http://localhost:5173"
			}
		}
	]
}
